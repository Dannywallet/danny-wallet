# Copy to .env and fill in real values:  cp .env.example .env

# WalletConnect — get a free Project ID at https://cloud.reown.com
NEXT_PUBLIC_WC_PROJECT_ID=""

# Admin key for the token-listing page (GET/PATCH /api/danny/listing) — set your own secret
LISTING_ADMIN_KEY="change-me-please"

# New listing-request notifications — Discord/Slack webhook (empty = disabled)
LISTING_NOTIFY_WEBHOOK=""

# Domain for Docker + Caddy (automatic HTTPS) — point the A record to the VPS IP first
DOMAIN=wallet.example.com
