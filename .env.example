# คัดลอกเป็น .env แล้วใส่ค่าจริง:  cp .env.example .env

# WalletConnect — ขอ Project ID ฟรีที่ https://cloud.reown.com
NEXT_PUBLIC_WC_PROJECT_ID=""

# กุญแจหน้าแอดมินลงลิสต์โทเคน (GET/PATCH /api/danny/listing) — ตั้งเป็นค่าลับของคุณเอง
LISTING_ADMIN_KEY="change-me-please"

# แจ้งเตือนคำขอลงลิสต์ใหม่ — webhook ของ Discord/Slack (เว้นว่าง = ปิด)
LISTING_NOTIFY_WEBHOOK=""

# โดเมนสำหรับ Docker + Caddy (HTTPS อัตโนมัติ) — ชี้ A record มาที่ IP ของ VPS ก่อน
DOMAIN=wallet.example.com
